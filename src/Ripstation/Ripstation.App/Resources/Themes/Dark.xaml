<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Accent (lighter blue readable on dark) -->
    <SolidColorBrush x:Key="AccentBrush"     Color="#4DA6FF" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#3A8FE8" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackgroundBrush"  Color="#1C1C1C" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#272727" />
    <SolidColorBrush x:Key="CardBorderBrush"     Color="#3C3C3C" />
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#2D2D2D" />
    <SolidColorBrush x:Key="SurfaceHoverBrush"   Color="#3A3A3A" />

    <!-- Text -->
    <SolidColorBrush x:Key="HeaderTextBrush" Color="#F3F3F3" />
    <SolidColorBrush x:Key="MutedTextBrush"  Color="#ABABAB" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="DangerBrush"  Color="#FF6B6B" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#6BCF6B" />

    <!-- Controls -->
    <SolidColorBrush x:Key="ControlBorderBrush"          Color="#555555" />
    <SolidColorBrush x:Key="DisabledAccentBrush"         Color="#444444" />
    <SolidColorBrush x:Key="DisabledAccentTextBrush"     Color="#888888" />
    <SolidColorBrush x:Key="SecondaryDisabledTextBrush"  Color="#666666" />

    <!-- DataGrid -->
    <SolidColorBrush x:Key="DataGridAltRowBrush"  Color="#232323" />
    <SolidColorBrush x:Key="ColumnHeaderBrush"    Color="#2A2A2A" />
    <SolidColorBrush x:Key="GridLineBrush"        Color="#363636" />
    <SolidColorBrush x:Key="SelectionBrush"       Color="#1A3C5C" />
    <SolidColorBrush x:Key="RowHoverBrush"        Color="#1A3045" />

    <!-- Misc -->
    <SolidColorBrush x:Key="ProgressTrackBrush"      Color="#3C3C3C" />
    <SolidColorBrush x:Key="TabCloseForegroundBrush" Color="#AAAAAA" />
    <SolidColorBrush x:Key="TabCloseHoverBgBrush"    Color="#5C1A1A" />
    <SolidColorBrush x:Key="StatusBarBrush"          Color="#1A1A1A" />
    <SolidColorBrush x:Key="StatusBarBorderBrush"    Color="#3C3C3C" />

</ResourceDictionary>
