<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBrush"     Color="#0067C0" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#005AA0" />

    <!-- Surfaces -->
    <SolidColorBrush x:Key="AppBackgroundBrush"  Color="#F3F3F3" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="CardBorderBrush"     Color="#E0E0E0" />
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceHoverBrush"   Color="#F0F0F0" />

    <!-- Text -->
    <SolidColorBrush x:Key="HeaderTextBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="MutedTextBrush"  Color="#767676" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="DangerBrush"  Color="#C42B1C" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#0F7B0F" />

    <!-- Controls -->
    <SolidColorBrush x:Key="ControlBorderBrush"          Color="#CCCCCC" />
    <SolidColorBrush x:Key="DisabledAccentBrush"         Color="#CCCCCC" />
    <SolidColorBrush x:Key="DisabledAccentTextBrush"     Color="#888888" />
    <SolidColorBrush x:Key="SecondaryDisabledTextBrush"  Color="#AAAAAA" />

    <!-- DataGrid -->
    <SolidColorBrush x:Key="DataGridAltRowBrush"  Color="#FAFAFA" />
    <SolidColorBrush x:Key="ColumnHeaderBrush"    Color="#F5F5F5" />
    <SolidColorBrush x:Key="GridLineBrush"        Color="#EEEEEE" />
    <SolidColorBrush x:Key="SelectionBrush"       Color="#E8F1FB" />
    <SolidColorBrush x:Key="RowHoverBrush"        Color="#F0F7FF" />

    <!-- Misc -->
    <SolidColorBrush x:Key="ProgressTrackBrush"     Color="#E0E0E0" />
    <SolidColorBrush x:Key="TabCloseForegroundBrush" Color="#666666" />
    <SolidColorBrush x:Key="TabCloseHoverBgBrush"   Color="#FFDDDD" />
    <SolidColorBrush x:Key="StatusBarBrush"         Color="#E8E8E8" />
    <SolidColorBrush x:Key="StatusBarBorderBrush"   Color="#D0D0D0" />

</ResourceDictionary>
