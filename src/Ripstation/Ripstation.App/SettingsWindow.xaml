<Window
    x:Class="Ripstation.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="using:Ripstation.Controls"
    Title="Settings">

    <Grid x:Name="ContentGrid" Background="{ThemeResource AppBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,20">

                <!--  Tool Paths ─ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Tool Paths" Style="{StaticResource SectionHeaderStyle}" />

                        <!-- MakeMKV -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MakeMKV CLI" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding MakeMkvExePath, Mode=TwoWay}" />
                            <ctrl:HandCursorButton Grid.Column="3" Content="Browse..."
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseMakeMkv_Click" />
                        </Grid>

                        <!-- HandBrake -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="HandBrakeCLI" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding HandBrakeExePath, Mode=TwoWay}" />
                            <ctrl:HandCursorButton Grid.Column="3" Content="Browse..."
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseHandBrake_Click" />
                        </Grid>

                        <!-- Preset file -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Preset File" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding PresetFilePath, Mode=TwoWay}" />
                            <ctrl:HandCursorButton Grid.Column="3" Content="Browse..."
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowsePreset_Click" />
                        </Grid>

                        <!-- Preset name -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="240" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Preset Name" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding PresetName, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  Output Paths ─ -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Output Paths" Style="{StaticResource SectionHeaderStyle}" />

                        <!-- Intermediate -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Intermediate (MKV)" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding IntermediatePath, Mode=TwoWay}" />
                            <ctrl:HandCursorButton Grid.Column="3" Content="Browse..."
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseIntermediate_Click" />
                        </Grid>

                        <!-- Output -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Output (M4V)" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding OutputPath, Mode=TwoWay}" />
                            <ctrl:HandCursorButton Grid.Column="3" Content="Browse..."
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseOutput_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Close -->
                <ctrl:HandCursorButton Content="Close"
                        Style="{StaticResource BrowseButtonStyle}"
                        HorizontalAlignment="Right"
                        Width="90"
                        Margin="0,4,0,0"
                        Click="Close_Click" />

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
