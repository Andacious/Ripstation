<Application
    x:Class="Ripstation.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Ripstation.Converters"
    xmlns:ctrl="using:Ripstation.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AccentBrush"     Color="#4DA6FF" />
                    <SolidColorBrush x:Key="AccentDarkBrush" Color="#3A8FE8" />
                    <SolidColorBrush x:Key="AppBackgroundBrush"  Color="#1C1C1C" />
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#272727" />
                    <SolidColorBrush x:Key="CardBorderBrush"     Color="#3C3C3C" />
                    <SolidColorBrush x:Key="SurfaceBrush"        Color="#2D2D2D" />
                    <SolidColorBrush x:Key="SurfaceHoverBrush"   Color="#3A3A3A" />
                    <SolidColorBrush x:Key="HeaderTextBrush"     Color="#F3F3F3" />
                    <SolidColorBrush x:Key="MutedTextBrush"      Color="#ABABAB" />
                    <SolidColorBrush x:Key="DangerBrush"         Color="#FF6B6B" />
                    <SolidColorBrush x:Key="SuccessBrush"        Color="#6BCF6B" />
                    <SolidColorBrush x:Key="ControlBorderBrush"          Color="#555555" />
                    <SolidColorBrush x:Key="DisabledAccentBrush"         Color="#444444" />
                    <SolidColorBrush x:Key="DisabledAccentTextBrush"     Color="#888888" />
                    <SolidColorBrush x:Key="SecondaryDisabledTextBrush"  Color="#666666" />
                    <SolidColorBrush x:Key="DataGridAltRowBrush"  Color="#232323" />
                    <SolidColorBrush x:Key="ColumnHeaderBrush"    Color="#2A2A2A" />
                    <SolidColorBrush x:Key="GridLineBrush"        Color="#363636" />
                    <SolidColorBrush x:Key="SelectionBrush"       Color="#1A3C5C" />
                    <SolidColorBrush x:Key="RowHoverBrush"        Color="#1A3045" />
                    <SolidColorBrush x:Key="ProgressTrackBrush"      Color="#3C3C3C" />
                    <SolidColorBrush x:Key="StatusBarBrush"          Color="#1A1A1A" />
                    <SolidColorBrush x:Key="StatusBarBorderBrush"    Color="#3C3C3C" />
                    <!-- TextBox system resource overrides — keeps dark bg on hover/focus -->
                    <SolidColorBrush x:Key="TextControlBackground"                  Color="#2D2D2D" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver"       Color="#3A3A3A" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused"           Color="#2D2D2D" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled"          Color="#232323" />
                    <SolidColorBrush x:Key="TextControlForeground"                  Color="#F3F3F3" />
                    <SolidColorBrush x:Key="TextControlForegroundPointerOver"       Color="#F3F3F3" />
                    <SolidColorBrush x:Key="TextControlForegroundFocused"           Color="#F3F3F3" />
                    <SolidColorBrush x:Key="TextControlForegroundDisabled"          Color="#666666" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground"             Color="#ABABAB" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver"  Color="#ABABAB" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"      Color="#888888" />
                    <SolidColorBrush x:Key="TextControlBorderBrush"                 Color="#555555" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"      Color="#777777" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused"          Color="#4DA6FF" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightColor"     Color="#1A3C5C" />
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AccentBrush"     Color="#0067C0" />
                    <SolidColorBrush x:Key="AccentDarkBrush" Color="#005AA0" />
                    <SolidColorBrush x:Key="AppBackgroundBrush"  Color="#F3F3F3" />
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="CardBorderBrush"     Color="#E0E0E0" />
                    <SolidColorBrush x:Key="SurfaceBrush"        Color="#FFFFFF" />
                    <SolidColorBrush x:Key="SurfaceHoverBrush"   Color="#F0F0F0" />
                    <SolidColorBrush x:Key="HeaderTextBrush"     Color="#1A1A1A" />
                    <SolidColorBrush x:Key="MutedTextBrush"      Color="#767676" />
                    <SolidColorBrush x:Key="DangerBrush"         Color="#C42B1C" />
                    <SolidColorBrush x:Key="SuccessBrush"        Color="#0F7B0F" />
                    <SolidColorBrush x:Key="ControlBorderBrush"          Color="#CCCCCC" />
                    <SolidColorBrush x:Key="DisabledAccentBrush"         Color="#CCCCCC" />
                    <SolidColorBrush x:Key="DisabledAccentTextBrush"     Color="#888888" />
                    <SolidColorBrush x:Key="SecondaryDisabledTextBrush"  Color="#AAAAAA" />
                    <SolidColorBrush x:Key="DataGridAltRowBrush"  Color="#FAFAFA" />
                    <SolidColorBrush x:Key="ColumnHeaderBrush"    Color="#F5F5F5" />
                    <SolidColorBrush x:Key="GridLineBrush"        Color="#EEEEEE" />
                    <SolidColorBrush x:Key="SelectionBrush"       Color="#E8F1FB" />
                    <SolidColorBrush x:Key="RowHoverBrush"        Color="#F0F7FF" />
                    <SolidColorBrush x:Key="ProgressTrackBrush"     Color="#E0E0E0" />
                    <SolidColorBrush x:Key="StatusBarBrush"         Color="#E8E8E8" />
                    <SolidColorBrush x:Key="StatusBarBorderBrush"   Color="#D0D0D0" />
                    <!-- TextBox system resource overrides — keeps light bg on hover/focus -->
                    <SolidColorBrush x:Key="TextControlBackground"                  Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver"       Color="#F5F5F5" />
                    <SolidColorBrush x:Key="TextControlBackgroundFocused"           Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TextControlBackgroundDisabled"          Color="#F0F0F0" />
                    <SolidColorBrush x:Key="TextControlForeground"                  Color="#1A1A1A" />
                    <SolidColorBrush x:Key="TextControlForegroundPointerOver"       Color="#1A1A1A" />
                    <SolidColorBrush x:Key="TextControlForegroundFocused"           Color="#1A1A1A" />
                    <SolidColorBrush x:Key="TextControlForegroundDisabled"          Color="#AAAAAA" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForeground"             Color="#767676" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver"  Color="#767676" />
                    <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"      Color="#999999" />
                    <SolidColorBrush x:Key="TextControlBorderBrush"                 Color="#CCCCCC" />
                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"      Color="#AAAAAA" />
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused"          Color="#0067C0" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightColor"     Color="#CCE0F5" />
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>

            <!-- Converters -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" TrueValue="Collapsed" FalseValue="Visible" />
            <conv:InverseBoolConverter x:Key="InvBool" />
            <conv:ProgressWidthConverter x:Key="ProgressWidth" />

            <!-- Typography -->
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource HeaderTextBrush}" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style x:Key="LabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource MutedTextBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Margin" Value="0,0,6,0" />
            </Style>

            <!-- Base TextBox style with key so IntTextBoxStyle can derive from it -->
            <Style x:Key="BaseTextBoxStyle" TargetType="TextBox">
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource HeaderTextBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}" />

            <Style x:Key="IntTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource BaseTextBoxStyle}">
                <Setter Property="Width" Value="70" />
                <Setter Property="TextAlignment" Value="Center" />
            </Style>

            <!-- Accent Button -->
            <Style x:Key="AccentButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="16,7" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{ThemeResource AccentDarkBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{ThemeResource AccentDarkBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{ThemeResource DisabledAccentBrush}" />
                                                <Setter Target="Content.Foreground" Value="{ThemeResource DisabledAccentTextBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                     </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="Content"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Secondary Button -->
            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource HeaderTextBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{ThemeResource SurfaceHoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{ThemeResource SurfaceHoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource SecondaryDisabledTextBrush}" />
                                                <Setter Target="RootBorder.BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="Content"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Danger Button -->
            <Style x:Key="DangerButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource SurfaceBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource DangerBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource DangerBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14,7" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{ThemeResource SurfaceHoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="{ThemeResource SurfaceHoverBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Content.Foreground" Value="{ThemeResource SecondaryDisabledTextBrush}" />
                                                <Setter Target="RootBorder.BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="Content"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Browse / small secondary button -->
            <Style x:Key="BrowseButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                <Setter Property="Padding" Value="8,5" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="MinWidth" Value="60" />
            </Style>

            <!-- Header bar settings button (white-on-accent) -->
            <Style x:Key="HeaderButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#CCE4FF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    Padding="{TemplateBinding Padding}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="#33FFFFFF" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="RootBorder.Background" Value="#55FFFFFF" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <ContentPresenter x:Name="Content"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  Foreground="{TemplateBinding Foreground}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Card Border -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <!-- RadioButton -->
            <Style TargetType="ctrl:HandCursorRadioButton">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Margin" Value="0,0,12,0" />
                <Setter Property="Foreground" Value="{ThemeResource HeaderTextBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ctrl:HandCursorRadioButton">
                            <Grid x:Name="Root">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Outer.Stroke" Value="{ThemeResource AccentBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Outer.Stroke" Value="{ThemeResource AccentBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Outer.Stroke" Value="{ThemeResource CardBorderBrush}" />
                                                <Setter Target="Inner.Fill" Value="{ThemeResource CardBorderBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="Inner.Visibility" Value="Visible" />
                                                <Setter Target="Outer.Stroke" Value="{ThemeResource AccentBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Unchecked" />
                                        <VisualState x:Name="Indeterminate" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Grid Width="16" Height="16" VerticalAlignment="Center">
                                        <Ellipse x:Name="Outer"
                                                 Stroke="{ThemeResource ControlBorderBrush}"
                                                 StrokeThickness="1.5"
                                                 Fill="{ThemeResource SurfaceBrush}" />
                                        <Ellipse x:Name="Inner"
                                                 Width="8" Height="8"
                                                 Fill="{ThemeResource AccentBrush}"
                                                 Visibility="Collapsed" />
                                    </Grid>
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Margin="6,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding Content}" />
                                </StackPanel>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- CheckBox -->
            <Style TargetType="ctrl:HandCursorCheckBox">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{ThemeResource HeaderTextBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ctrl:HandCursorCheckBox">
                            <Grid x:Name="Root">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal" />
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="Box.BorderBrush" Value="{ThemeResource AccentBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="Box.BorderBrush" Value="{ThemeResource AccentBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <VisualState.Setters>
                                                <Setter Target="Box.BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                                                <Setter Target="Box.Background" Value="{ThemeResource CardBorderBrush}" />
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="CheckStates">
                                        <VisualState x:Name="Checked">
                                            <VisualState.Setters>
                                                <Setter Target="Box.Background" Value="{ThemeResource AccentBrush}" />
                                                <Setter Target="Box.BorderBrush" Value="{ThemeResource AccentBrush}" />
                                                <Setter Target="Check.Visibility" Value="Visible" />
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Unchecked" />
                                        <VisualState x:Name="Indeterminate" />
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border x:Name="Box"
                                            Width="16" Height="16"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource SurfaceBrush}"
                                            BorderBrush="{ThemeResource ControlBorderBrush}"
                                            BorderThickness="1.5"
                                            CornerRadius="3">
                                        <Path x:Name="Check"
                                              Data="M 2 7 L 6 11 L 13 3"
                                              Stroke="White"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Visibility="Collapsed"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Border>
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Margin="6,0,0,0"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding Content}" />
                                </StackPanel>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>


