<Window x:Class="Ripstation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Ripstation.ViewModels"
        Title="Ripstation"
        Width="1100" Height="860"
        MinWidth="820" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        Loaded="OnLoaded">

    <Window.Resources>
        <Style x:Key="PathRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <!-- Close button for tab header -->
        <Style x:Key="TabCloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TabCloseForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TabCloseHoverBgBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataTemplate for DriveViewModel tabs -->
        <DataTemplate x:Key="DriveTabContentTemplate" DataType="{x:Type vm:DriveViewModel}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4,4,4">
                <StackPanel>

                    <!-- ── Scan ─────────────────────────────────────────── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Scan Disc" Style="{StaticResource SectionHeaderStyle}" />

                            <!-- Scan button + inline progress -->
                            <StackPanel Orientation="Horizontal">
                                <Button Content="⊙  Scan" Style="{StaticResource AccentButtonStyle}"
                                        Command="{Binding ScanCommand}" />
                                <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center"
                                            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                                    <ProgressBar Width="180" Value="{Binding ScanProgress, Mode=OneWay}"
                                                 Minimum="0" Maximum="100" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding ScanStatus}" FontSize="12"
                                               Foreground="{DynamicResource MutedTextBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Disc name after scan -->
                            <TextBlock Text="{Binding DiscName}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,10,0,0"
                                       Visibility="{Binding IsDiscNameVisible, Converter={StaticResource BoolToVis}}" />

                            <!-- Scan complete status -->
                            <TextBlock Text="{Binding ScanStatus}"
                                       FontSize="12" Foreground="{DynamicResource MutedTextBrush}"
                                       Margin="0,6,0,0"
                                       Visibility="{Binding IsScanStatusVisible, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Border>

                    <!-- ── Titles ───────────────────────────────────────── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,10">
                                <TextBlock Text="Titles" Style="{StaticResource SectionHeaderStyle}"
                                           Margin="0" VerticalAlignment="Center" DockPanel.Dock="Left" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Select All" Style="{StaticResource BrowseButtonStyle}"
                                            Command="{Binding SelectAllCommand}" Margin="0,0,6,0" />
                                    <Button Content="Deselect All" Style="{StaticResource BrowseButtonStyle}"
                                            Command="{Binding DeselectAllCommand}" />
                                </StackPanel>
                            </DockPanel>

                            <DataGrid ItemsSource="{Binding Titles}" MaxHeight="240"
                                      IsReadOnly="False">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="✓" Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="36" />
                                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="44" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Chapters" Binding="{Binding Chapters}" Width="72" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Duration" Binding="{Binding DurationDisplay}" Width="80" IsReadOnly="True" />
                                    <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="80" IsReadOnly="True" />
                                    <DataGridTextColumn Header="File" Binding="{Binding FileName}" Width="160" IsReadOnly="True" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Text="{Binding SelectedTitleCount, StringFormat='{}{0} title(s) selected'}"
                                       FontSize="12" Foreground="{DynamicResource MutedTextBrush}" Margin="0,8,0,0"
                                       Visibility="{Binding HasTitles, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Border>

                    <!-- ── Media Settings ───────────────────────────────── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Media Settings" Style="{StaticResource SectionHeaderStyle}" />

                            <!-- Movie / TV -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Movie" GroupName="{Binding DiskNumber}"
                                             IsChecked="{Binding IsTvMode, Converter={StaticResource InvBool}}" />
                                <RadioButton Content="TV Show" GroupName="{Binding DiskNumber}"
                                             IsChecked="{Binding IsTvMode}" />
                            </StackPanel>

                            <!-- Name -->
                            <Grid Style="{StaticResource PathRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Media Name (optional)" Style="{StaticResource LabelStyle}" />
                                <TextBox Grid.Column="1" Text="{Binding MediaName, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Leave blank to use the disc/title name" />
                            </Grid>

                            <!-- TV: Season / Episodes -->
                            <StackPanel Orientation="Horizontal"
                                        Visibility="{Binding IsTvShow, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Season" Style="{StaticResource LabelStyle}" />
                                <TextBox Style="{StaticResource IntTextBoxStyle}"
                                         Text="{Binding Season, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Ep Start" Style="{StaticResource LabelStyle}" Margin="12,0,6,0" />
                                <TextBox Style="{StaticResource IntTextBoxStyle}"
                                         Text="{Binding EpisodeStart, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="Ep End" Style="{StaticResource LabelStyle}" Margin="12,0,6,0" />
                                <TextBox Style="{StaticResource IntTextBoxStyle}"
                                         Text="{Binding EpisodeEnd, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="{Binding EpisodeCount, StringFormat='{}{0} episodes'}"
                                           Style="{StaticResource LabelStyle}" Margin="10,0,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- ── Per-Drive Actions ─────────────────────────────── -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Actions" Style="{StaticResource SectionHeaderStyle}" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="▶  Rip" Style="{StaticResource AccentButtonStyle}"
                                        Command="{Binding RipStandaloneCommand}" Margin="0,0,8,0" />
                                <Button Content="⬛  Cancel" Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding CancelCommand}" Margin="0,0,8,0" />
                                <Button Content="⏏  Eject" Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding EjectCommand}" />
                            </StackPanel>

                            <CheckBox Content="Auto-eject when done"
                                      IsChecked="{Binding EjectWhenDone}"
                                      Margin="0,0,0,12" />

                            <!-- Per-drive rip progress -->
                            <Grid Visibility="{Binding IsRipping, Converter={StaticResource BoolToVis}}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ProgressBar Grid.Row="0" Value="{Binding RipProgress, Mode=OneWay}"
                                             Minimum="0" Maximum="100" Margin="0,0,0,4" />
                                <TextBlock Grid.Row="1" Text="{Binding RipStatus}"
                                           FontSize="12" Foreground="{DynamicResource MutedTextBrush}" />
                            </Grid>

                            <!-- Last rip status (only when idle and has a result) -->
                            <TextBlock Text="{Binding RipStatus}"
                                       FontSize="12" Foreground="{DynamicResource MutedTextBrush}"
                                       Visibility="{Binding IsRipStatusIdleVisible, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />   <!-- Header bar -->
            <RowDefinition Height="*" />    <!-- Scrollable content -->
            <RowDefinition Height="Auto" /> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER BAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}">
            <DockPanel Margin="20,0">
                <TextBlock Text="Ripstation"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White"
                           VerticalAlignment="Center" />
                <TextBlock Text="Disc ripper · MakeMKV + HandBrake"
                           FontSize="12" Foreground="#CCE4FF"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0" />
            </DockPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16,20,4">
            <StackPanel>

                <!-- ── GLOBAL: Tool Paths ─────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Tool Paths" Style="{StaticResource SectionHeaderStyle}" />

                        <!-- MakeMKV -->
                        <Grid Style="{StaticResource PathRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="MakeMKV CLI" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Settings.MakeMkvExePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="3" Content="Browse…"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseMakeMkv_Click" />
                        </Grid>

                        <!-- HandBrake -->
                        <Grid Style="{StaticResource PathRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="HandBrakeCLI" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Settings.HandBrakeExePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="3" Content="Browse…"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseHandBrake_Click" />
                        </Grid>

                        <!-- Preset file -->
                        <Grid Style="{StaticResource PathRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Preset File" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Settings.PresetFilePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="3" Content="Browse…"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowsePreset_Click" />
                        </Grid>

                        <!-- Preset name -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="240" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Preset Name" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Settings.PresetName, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── GLOBAL: Output Paths ──────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Output Paths" Style="{StaticResource SectionHeaderStyle}" />

                        <!-- Intermediate -->
                        <Grid Style="{StaticResource PathRowStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Intermediate (MKV)" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Settings.IntermediatePath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="3" Content="Browse…"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseIntermediate_Click" />
                        </Grid>

                        <!-- Output -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Output (M4V)" Style="{StaticResource LabelStyle}" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding Settings.OutputPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="3" Content="Browse…"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="BrowseOutput_Click" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── DRIVES (TabControl) ───────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}" Padding="0">
                    <StackPanel>
                        <!-- Tab bar header row -->
                        <DockPanel Margin="16,12,16,0">
                            <TextBlock Text="Drives" Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Detect Drives" Style="{StaticResource BrowseButtonStyle}"
                                        Command="{Binding DetectDrivesCommand}" Margin="0,0,6,0" />
                                <Button Content="+ Add Drive" Style="{StaticResource BrowseButtonStyle}"
                                        Command="{Binding AddDriveCommand}" />
                            </StackPanel>
                        </DockPanel>

                        <TabControl ItemsSource="{Binding Drives}"
                                    ContentTemplate="{StaticResource DriveTabContentTemplate}"
                                    SelectedIndex="0"
                                    Margin="8,8,8,8"
                                    MinHeight="520">
                            <TabControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DriveViewModel}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TabHeader}"
                                                   VerticalAlignment="Center" FontSize="12" />
                                        <Button Content="×"
                                                Style="{StaticResource TabCloseButtonStyle}"
                                                Command="{Binding DataContext.RemoveDriveCommand,
                                                    RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                CommandParameter="{Binding}" />
                                    </StackPanel>
                                </DataTemplate>
                            </TabControl.ItemTemplate>
                        </TabControl>
                    </StackPanel>
                </Border>

                <!-- ── GLOBAL ACTIONS ────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Global Actions" Style="{StaticResource SectionHeaderStyle}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶▶  Rip All Drives" Style="{StaticResource AccentButtonStyle}"
                                    Command="{Binding RipAllCommand}" Margin="0,0,8,0" />
                            <Button Content="⬛  Cancel All" Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding CancelAllCommand}" Margin="0,0,8,0" />
                            <Button Content="⏏  Eject All" Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding EjectAllCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── LOG ─────────────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="Log" Style="{StaticResource SectionHeaderStyle}"
                                       Margin="0" VerticalAlignment="Center" DockPanel.Dock="Left" />
                            <Button Content="Clear" HorizontalAlignment="Right"
                                    Style="{StaticResource BrowseButtonStyle}"
                                    Click="ClearLog_Click" />
                        </DockPanel>
                        <ListBox x:Name="LogListBox"
                                 ItemsSource="{Binding LogLines}"
                                 Height="180"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="#1E1E1E" Foreground="#DCDCDC"
                                 BorderThickness="0"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ STATUS BAR ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBrush}" BorderBrush="{DynamicResource StatusBarBorderBrush}"
                BorderThickness="0,1,0,0" Padding="16,4">
            <TextBlock FontSize="11" Foreground="{DynamicResource MutedTextBrush}">
                <Run Text="{Binding Drives.Count, StringFormat='{}{0} drive(s)', Mode=OneWay}" />
                <Run Text=" · " />
                <Run Text="{Binding Settings.OutputPath, Mode=OneWay}" />
            </TextBlock>
        </Border>

    </Grid>
</Window>
